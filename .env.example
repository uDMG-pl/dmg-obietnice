# Cloudflare Turnstile (widget type: Invisible)
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# MongoDB (obietnice, zgloszenia, rate_limits)
MONGODB_URI=
MONGODB_DB=
MONGODB_COLLECTION=obietnice

# Limit zgłoszeń na IP (domyślnie: 5 na 15 min)
ZGLOS_RATE_LIMIT_MAX=5
ZGLOS_RATE_LIMIT_WINDOW_SEC=900
